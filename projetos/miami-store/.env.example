# =============================================
# Miami Store — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env (mesma pasta) e preencha os valores reais.
# Esse .env é lido pelo docker compose (em projetos/miami-store/infra/docker-compose.yml).

# --- Anthropic (apenas pra orquestração de agentes Claude Code) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Banco de Dados PostgreSQL ---
# Em desenvolvimento local via Docker, o host do banco É o nome do serviço
# do compose ("postgres"). Não use "localhost" aqui — o backend roda dentro
# de um container e localhost = o próprio container.
DB_USER=postgres
DB_PASSWORD=postgres_dev_only_change_me
DB_NAME=miami_store
DB_PORT=5432
# DATABASE_URL é montada automaticamente pelo docker-compose. Se for rodar
# o backend FORA do docker (ex.: prisma studio na máquina host), use:
DATABASE_URL=postgresql://postgres:postgres_dev_only_change_me@localhost:5432/miami_store?schema=public

# --- Autenticação ---
# JWT_SECRET: gere um forte: openssl rand -base64 48
JWT_SECRET=troque_isso_em_producao_use_openssl_rand_base64_48
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# --- CORS ---
# Lista de origins permitidos, separados por vírgula. Em produção, NUNCA use *.
CORS_ORIGIN=http://miami.test,http://admin.miami.test,http://localhost,http://localhost:3000,http://localhost:3002

# --- Cookie domain ---
# Compartilha sessão entre subdomínios (.miami.test = loja + painel + api).
# Pra usar, precisa adicionar ao C:\Windows\System32\drivers\etc\hosts:
#   127.0.0.1 miami.test admin.miami.test api.miami.test
# Vazio = cookie só vale no host exato (default Express).
COOKIE_DOMAIN=.miami.test

# --- Pagamentos MercadoPago (gere em mercadopago.com.br/developers) ---
# TEST-xxx pra sandbox, APP_USR-xxx em produção
MERCADOPAGO_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxxxxxxxxxxx
# Webhook URL que o MercadoPago vai chamar quando atualizar status de pagamento
MERCADOPAGO_WEBHOOK_URL=http://localhost/api/webhooks/mercadopago
# Secret de assinatura do webhook (configurado em "Suas integrações" no painel MP).
# Vazio em dev = webhook aceito sem verificação (com warning). Em prod, obrigatório.
MERCADOPAGO_WEBHOOK_SECRET=

# --- Portas dos serviços (host) ---
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000
DASHBOARD_PORT=3002
# Nginx expõe a porta 80 (não configurável via env neste sprint)

# --- Endereço de origem do envio (pra cálculo de frete) ---
SHIPPING_ORIGIN_CEP=01310-100
SHIPPING_FLAT_RATE=15.00

# --- WhatsApp do lojista (botão flutuante na loja) ---
WHATSAPP_NUMBER=5511999999999
WHATSAPP_DEFAULT_MESSAGE=Olá! Vi a Miami Store no Insta e quero tirar uma dúvida.

# --- API externa de CEP ---
CEP_API_URL=https://viacep.com.br/ws

# --- Seed (admin inicial) ---
# Sem default. Defina uma senha forte (10+ chars, mistura) ANTES de rodar
# `npm run prisma:seed`. Se ficar vazio, o seed pula a criação do admin.
SEED_ADMIN_EMAIL=admin@miami.store
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin Miami Store
