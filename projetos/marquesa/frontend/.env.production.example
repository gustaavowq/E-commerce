# =============================================================================
# Marquesa Frontend — env de PRODUCAO
# Copiar pra frontend/.env.production na VPS.
# Vars NEXT_PUBLIC_* sao expostas ao browser — nao colocar segredos aqui.
# =============================================================================

# API publica (browser bate aqui via mesmo dominio + /api/)
NEXT_PUBLIC_API_URL=https://marquesa.gustavo.agenciaever.cloud

# API interna (SSR -> direto pelo container, evita ir ate nginx -> volta)
INTERNAL_API_URL=http://api:8211

# Site publico (usado em metadata, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://marquesa.gustavo.agenciaever.cloud

# Contato
NEXT_PUBLIC_WHATSAPP_NUMBER=5511900000000
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Ola, vi um imovel no site da Marquesa e gostaria de mais informacoes.

# Analytics (placeholders — preencher quando GA4/Pixel forem ativados)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=

NODE_ENV=production
