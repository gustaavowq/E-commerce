# API base URL — public (browser) e interno (SSR)
NEXT_PUBLIC_API_URL=http://localhost:8211
INTERNAL_API_URL=http://localhost:8211

# WhatsApp do corretor (lead/contato)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511900000000
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Olá, vi um imóvel no site da Marquesa e gostaria de mais informações.

# Domínio público em prod (pra absolute URLs em metadata/share)
NEXT_PUBLIC_SITE_URL=https://marquesa.gustavo.agenciaever.cloud

# Analytics (opcionais). Sem ID, scripts não carregam.
# GA4 measurement ID — formato G-XXXXXXX
NEXT_PUBLIC_GA4_ID=
# Meta (Facebook) Pixel ID — só dígitos
NEXT_PUBLIC_META_PIXEL_ID=
