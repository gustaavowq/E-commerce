// =============================================================================
// Marquesa — Schema do banco de dados
// Imobiliária boutique. Reserva por sinal (5% default via MP Pix), 10 dias bloqueia imóvel.
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  // Engine pra dev (Windows native) + container Alpine/Debian.
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Role {
  USER      // cliente comprador, redirect pra /
  ADMIN     // corretor/dono, redirect pra /painel
  ANALYST   // analista de dados, redirect pra /painel/dashboard (somente leitura)
}

enum ImovelTipo {
  APARTAMENTO
  CASA
  COBERTURA
  SOBRADO
  TERRENO
  COMERCIAL
}

enum ImovelStatus {
  DISPONIVEL       // catálogo, recebe interessados
  RESERVADO        // sinal pago, 10 dias bloqueado
  EM_NEGOCIACAO    // após reserva expirar com cliente ainda interessado
  VENDIDO          // contrato assinado offline
  INATIVO          // tirado do ar (soft delete)
}

enum ReservaStatus {
  ATIVA       // sinal pago, dentro do prazo de 10d
  EXPIRADA    // 10d passaram sem fechar
  CANCELADA   // cliente ou admin cancelou
  CONVERTIDA  // virou venda (admin marcou)
}

enum PagamentoStatus {
  PENDENTE
  APROVADO
  REJEITADO
  CANCELADO
  REEMBOLSADO
}

// -----------------------------------------------------------------------------
// USERS & AUTH
// -----------------------------------------------------------------------------

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  name            String
  phone           String?
  role            Role      @default(USER)
  emailVerifiedAt DateTime? @map("email_verified_at")

  reservas             Reserva[]
  leads                Lead[]
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([role])
  @@map("users")
}

model RefreshToken {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  // Quando rotaciona, marca qual token substituiu este. Detecta reuso.
  replacedById String?   @map("replaced_by_id")
  userAgent    String?   @map("user_agent")
  ip           String?
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  ip         String?
  userAgent  String?   @map("user_agent")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// -----------------------------------------------------------------------------
// IMÓVEIS — catálogo
// -----------------------------------------------------------------------------

model Imovel {
  id          String       @id @default(cuid())
  slug        String       @unique
  titulo      String
  descricao   String       @db.Text
  tipo        ImovelTipo
  status      ImovelStatus @default(DISPONIVEL)

  // Preço (Decimal pra precisão financeira)
  preco       Decimal      @db.Decimal(12, 2)
  // Sinal calculado (default 5% do preço, configurável). Se null, usa SINAL_DEFAULT_PERCENT do env.
  precoSinal  Decimal      @db.Decimal(12, 2) @map("preco_sinal")

  // Características físicas
  area        Float        // m² (área útil)
  areaTotal   Float?       @map("area_total")  // m² total (terreno/comum)
  quartos     Int
  suites      Int          @default(0)
  banheiros   Int
  vagas       Int          @default(0)

  // Endereço (logradouro fictício, coords em mata)
  endereco    String
  bairro      String
  cidade      String
  estado      String
  cep         String
  latitude    Float
  longitude   Float

  // Mídia
  fotos       String[]     // URLs Cloudinary ou Unsplash
  videoUrl    String?      @map("video_url")
  tourUrl     String?      @map("tour_url")  // 360º (futuro)

  // Flags
  destaque    Boolean      @default(false)
  novidade    Boolean      @default(false)

  // Custos recorrentes
  iptuAnual   Decimal?     @db.Decimal(10, 2) @map("iptu_anual")
  condominio  Decimal?     @db.Decimal(8, 2)

  // Comodidades opcionais (string array pra simplificar — ex: ["piscina","academia","sauna"])
  amenidades  String[]     @default([])

  // KPIs de engajamento (Data-Analyst). viewCount soma POST /api/imoveis/:slug/view.
  // lastInteractionAt = max(view, lead, reserva) — usado pra ranking "estagnados".
  viewCount         Int       @default(0) @map("view_count")
  lastViewedAt      DateTime? @map("last_viewed_at")
  lastInteractionAt DateTime? @map("last_interaction_at")

  reservas    Reserva[]
  leads       Lead[]

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([status])
  @@index([tipo, status])
  @@index([cidade, bairro])
  @@index([destaque, status])
  @@index([viewCount])
  @@index([lastInteractionAt])
  @@map("imoveis")
}

// -----------------------------------------------------------------------------
// RESERVA — sinal pago, trava imóvel por 7 dias
// -----------------------------------------------------------------------------

model Reserva {
  id              String          @id @default(cuid())
  imovelId        String          @map("imovel_id")
  imovel          Imovel          @relation(fields: [imovelId], references: [id])
  userId          String          @map("user_id")
  user            User            @relation(fields: [userId], references: [id])

  status          ReservaStatus   @default(ATIVA)
  pagamentoStatus PagamentoStatus @default(PENDENTE) @map("pagamento_status")

  valorSinal      Decimal         @db.Decimal(12, 2) @map("valor_sinal")
  // Snapshot do preço do imóvel no momento da reserva (não mexe se o imóvel mudar de preço depois)
  precoSnapshot   Decimal         @db.Decimal(12, 2) @default(0) @map("preco_snapshot")

  // MercadoPago
  mpPaymentId     String?         @unique @map("mp_payment_id")
  mpPreferenceId  String?         @map("mp_preference_id")
  mpInitPoint     String?         @map("mp_init_point")  // URL pra cliente pagar
  // Idempotência do webhook
  webhookEventId  String?         @unique @map("webhook_event_id")

  // Datas críticas
  paidAt          DateTime?       @map("paid_at")
  expiraEm        DateTime        @map("expira_em")  // paidAt + RESERVA_DURACAO_DIAS (default 10d)
  canceladaEm     DateTime?       @map("cancelada_em")
  expiradaEm      DateTime?       @map("expirada_em")
  convertidaEm    DateTime?       @map("convertida_em")
  notesAdmin      String?         @map("notes_admin") @db.Text

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([imovelId, status])
  @@index([userId])
  @@index([status, expiraEm])
  @@index([pagamentoStatus])
  @@map("reservas")
}

// -----------------------------------------------------------------------------
// LEAD — formulário de interesse num imóvel (sem pagamento)
// -----------------------------------------------------------------------------

model Lead {
  id        String   @id @default(cuid())
  imovelId  String   @map("imovel_id")
  imovel    Imovel   @relation(fields: [imovelId], references: [id])
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])

  nome      String
  email     String
  telefone  String?
  mensagem  String?  @db.Text

  // Status simples (corretor pode marcar como contatado pelo painel)
  contatado    Boolean  @default(false)
  contatadoEm  DateTime? @map("contatado_em")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([imovelId])
  @@index([userId])
  @@index([createdAt])
  @@map("leads")
}

// -----------------------------------------------------------------------------
// SETTINGS — config global da imobiliária (singleton id="default")
// -----------------------------------------------------------------------------
model SiteSettings {
  id                    String   @id @default("default")
  storeName             String   @default("Marquesa") @map("store_name")
  storeTagline          String?  @map("store_tagline")
  logoUrl               String?  @map("logo_url")
  faviconUrl            String?  @map("favicon_url")

  whatsappNumber        String?  @map("whatsapp_number")
  whatsappMessage       String?  @map("whatsapp_message") @db.Text
  instagramHandle       String?  @map("instagram_handle")
  email                 String?
  phone                 String?

  // Empresa (CRECI etc)
  cnpj                  String?
  legalName             String?  @map("legal_name")
  creci                 String?
  address               String?

  // Conteúdo legal (markdown)
  privacyPolicy         String?  @map("privacy_policy") @db.Text
  termsOfUse            String?  @map("terms_of_use") @db.Text
  reservaPolicy         String?  @map("reserva_policy") @db.Text
  aboutUs               String?  @map("about_us") @db.Text

  // Comercial
  sinalDefaultPercent   Int      @default(5) @map("sinal_default_percent")
  reservaDuracaoDias    Int      @default(10) @map("reserva_duracao_dias")

  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
