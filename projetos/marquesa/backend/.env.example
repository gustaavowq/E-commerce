# ============================================================================
# Marquesa — Backend env vars
# Copie pra .env e preencha. NUNCA comitar .env.
# ============================================================================

NODE_ENV="development"
PORT=8211
LOG_LEVEL="info"

# Database (Postgres 16). Em prod (VPS), aponta pro container gustavo-marquesa-db.
DATABASE_URL="postgresql://marquesa:senha@localhost:5432/marquesa?schema=public"

# JWT — TROCAR em prod. Mínimo 32 chars cada.
JWT_SECRET="dev_only_jwt_secret_change_me_change_me_now_64chars_at_least_okay"
JWT_REFRESH_SECRET="dev_only_jwt_refresh_secret_change_me_change_me_now_64chars_okay"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS — vírgula separa origins
# Dev: http://localhost:3000
# Prod: https://marquesa.gustavo.agenciaever.cloud
CORS_ORIGIN="http://localhost:3000"

# Cookie config
# COOKIE_DOMAIN: deixa vazio em dev (default: host exato).
#   Em prod, NÃO setar — sub-dominio único, default funciona.
COOKIE_DOMAIN=""
COOKIE_SAMESITE="lax"
COOKIE_SECURE=false

# URL pública (em prod aponta pro nginx). Usado pra build de URLs (reset, MP).
PUBLIC_API_URL="http://localhost:8211"
PUBLIC_WEB_URL="http://localhost:3000"

# MercadoPago — sinal de reserva (Pix preferencial)
# Dev: deixa vazio pra usar mock. Prod: tem que ser PRODUCTION token.
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Sinal default (% do preço). Imóvel pode sobrescrever via campo precoSinal.
SINAL_DEFAULT_PERCENT=5

# Reserva: dias até expirar após pagamento aprovado
RESERVA_DURACAO_DIAS=10

# Seed (admin/cliente iniciais). Se vazio, gera senha random e printa no console.
SEED_ADMIN_EMAIL="admin@marquesa.dev"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Admin Marquesa"

SEED_CLIENTE_EMAIL="cliente@marquesa.dev"
SEED_CLIENTE_PASSWORD=""
SEED_CLIENTE_NAME="Cliente Demo"

# Contato exibido na loja (placeholder do brief)
WHATSAPP_NUMBER="+5511900000000"
CONTACT_EMAIL="contato@marquesa.dev"
