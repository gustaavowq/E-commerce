# =============================================================================
# Marquesa — gitignore (raiz do projeto)
# Memoria 30-LICOES: env nunca comitado, mas .example sempre vai.
# =============================================================================

# env (todos os formatos)
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.test
!**/.env.example
!**/.env.production.example

# deps
**/node_modules

# build outputs
**/.next
**/dist
**/build
**/*.tsbuildinfo

# Prisma artifacts (gerado)
**/prisma/migrations/dev.db*
**/prisma/.db.tmp/

# logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/pnpm-debug.log*

# coverage
**/coverage/
**/.nyc_output/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker overrides locais
**/docker-compose.override.yml

# Backups DB locais
*.sql
!**/seed/*.sql
