# =============================================================================
# Kore Tech — gitignore
# =============================================================================

# Dependencies
node_modules/

# Build artifacts
.next/
dist/
build/
*.tsbuildinfo

# Env files (so .env.example fica no repo)
.env
.env.local
.env.*.local
!.env.example

# Bloqueia .env em qualquer subpasta (lição #06 do Miami: nada de .env em infra/)
**/.env
!**/.env.example

# Prisma artefatos locais
prisma/dev.db
prisma/dev.db-journal
prisma/migrations/dev/

# Cache
.turbo/
.cache/
.parcel-cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Coverage
coverage/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Vercel
.vercel/

# Docker
docker-compose.override.yml
