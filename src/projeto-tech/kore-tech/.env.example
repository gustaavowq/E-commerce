# =============================================================================
# Kore Tech — Variaveis de ambiente (template)
#
# Como usar:
#   1. cp .env.example .env  (na raiz src/projeto-tech/kore-tech/)
#   2. Editar valores marcados com TROCAR_ANTES_DE_*
#   3. NUNCA commitar .env (so .env.example)
#   4. NAO criar outro .env dentro de infra/ — Compose carrega o local primeiro
#      e sobrescreve este (lição #06 do Miami).
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados (PostgreSQL — container "postgres" no compose)
# -----------------------------------------------------------------------------
DB_USER=kore
DB_PASSWORD=kore
DB_NAME=kore_tech
DB_PORT=5433
# DATABASE_URL e montada pelo compose; aqui so se backend rodar fora de docker
DATABASE_URL=postgresql://kore:kore@postgres:5432/kore_tech?schema=public

# -----------------------------------------------------------------------------
# Backend (Node + Express + Prisma)
# -----------------------------------------------------------------------------
BACKEND_PORT=4001
NODE_ENV=development

# JWT — TROCAR ANTES DE QUALQUER USO REAL.
# Gerar com:  openssl rand -base64 48
# Lição #01 do Miami: placeholder = qualquer um forja token de admin.
JWT_SECRET=TROCAR_ANTES_DE_DEPLOY_openssl_rand_-base64_48
JWT_EXPIRES_IN=7d

# Cookie domain — em dev deixar VAZIO (cookie escopa pelo host atual).
# Em prod, setar pro APEX (.kore.tech) pra cookie funcionar entre subdominios.
COOKIE_DOMAIN=

# CORS — origens autorizadas (separado por virgula, SEM espaco).
# Lição #07 do Miami: nunca deixar "*"; lista explicita dos hosts reais.
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://loja.kore.test:8081,http://admin.kore.test:8081

# Seed do admin inicial (so executa em "npx prisma db seed", nao no boot).
# Lição #04 do Miami: senha forte, >= 10 chars, especial.
SEED_ADMIN_EMAIL=admin@kore.tech
SEED_ADMIN_PASSWORD=TROCAR_ANTES_DE_RODAR_SEED

# -----------------------------------------------------------------------------
# MercadoPago — pagamentos (Pix focus)
# Onde pegar:  https://www.mercadopago.com.br/developers/panel/app
# Sandbox: tokens "TEST-..."  |  Producao: "APP_USR-..."
# -----------------------------------------------------------------------------
MP_ACCESS_TOKEN=APP_USR-PLACEHOLDER
MP_WEBHOOK_SECRET=PLACEHOLDER

# -----------------------------------------------------------------------------
# Cloudinary — upload de imagens de produto/build
# Onde pegar:  https://cloudinary.com/console (Dashboard > API Environment variable)
# Formato:     cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# -----------------------------------------------------------------------------
CLOUDINARY_URL=cloudinary://PLACEHOLDER

# -----------------------------------------------------------------------------
# Resend — emails transacionais (boas-vindas, pedido, lista de espera)
# Onde pegar:  https://resend.com/api-keys
# RESEND_FROM precisa ser dominio verificado em Resend.
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_PLACEHOLDER
RESEND_FROM=noreply@kore.tech

# -----------------------------------------------------------------------------
# Frontend (Next.js loja)
# -----------------------------------------------------------------------------
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:4001
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3002
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Quero tirar uma duvida sobre um build.

# -----------------------------------------------------------------------------
# Dashboard (Next.js painel)
# -----------------------------------------------------------------------------
DASHBOARD_PORT=3002

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_PORT=8081
