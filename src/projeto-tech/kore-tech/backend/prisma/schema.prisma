// =============================================================================
// Kore Tech — Schema do banco de dados
// E-commerce de hardware/PC: componentes avulsos + PCs montados +
// PC Builder (com regras de compatibilidade) + Personas + Lista de espera.
//
// Mantido pelo Backend (Agente 01). Decisões em projetos/projeto-tech/kore-tech/.
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  // Garante que o Prisma baixa engines pra Windows (dev local) e Debian
  // (container Docker). Sem isso, trocar de SO causa "Could not locate the
  // Query Engine" — o volume anônimo do compose persiste binários da build
  // anterior.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT  // pedido criado, aguardando pagamento
  PAID             // pagamento confirmado
  PREPARING        // em separação / montando (BTO de PC)
  SHIPPED          // enviado
  DELIVERED        // entregue
  CANCELLED        // cancelado (timeout ou ação do cliente/admin)
  REFUNDED         // reembolsado
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  BOLETO
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELLED
  EXPIRED
}

enum CouponType {
  PERCENT      // ex: 10% off
  FIXED        // ex: R$ 200 off
  FREE_SHIPPING
}

// -----------------------------------------------------------------------------
// USERS & AUTH
// -----------------------------------------------------------------------------

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  name            String
  phone           String?
  cpf             String?   @unique
  role            Role      @default(CUSTOMER)
  emailVerifiedAt DateTime? @map("email_verified_at")

  addresses           Address[]
  orders              Order[]
  carts               Cart[]
  reviews             Review[]
  wishlist            WishlistItem[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  pcBuilds            PCBuild[]
  waitlist            WaitlistSubscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([role])
  @@map("users")
}

model RefreshToken {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  // Quando rotaciona, marca qual token substituiu este. Se alguém tentar usar
  // um token revogado E que tem replacedBy → token roubado, revoga toda a chain.
  replacedById String?   @map("replaced_by_id")
  userAgent    String?   @map("user_agent")
  ip           String?
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// Token pra reset de senha. Mesmo padrão dos refresh: guardamos só o HASH no
// banco, o raw vai pelo email/whatsapp. Single-use (usedAt) e expira em 1h.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  ip        String?
  userAgent String?   @map("user_agent")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// -----------------------------------------------------------------------------
// STORE SETTINGS — config global da loja (singleton, id="default")
// -----------------------------------------------------------------------------
model StoreSettings {
  id              String   @id @default("default")
  storeName       String   @default("Kore Tech")        @map("store_name")
  storeTagline    String?  @map("store_tagline")
  logoUrl         String?  @map("logo_url")
  faviconUrl      String?  @map("favicon_url")

  // Contato visível pro cliente
  whatsappNumber  String?  @map("whatsapp_number")  // ex "5511999999999"
  whatsappMessage String?  @map("whatsapp_message") @db.Text
  instagramHandle String?  @map("instagram_handle")
  email           String?
  phone           String?

  // Empresa
  cnpj            String?
  legalName       String?  @map("legal_name")
  address         String?

  // Conteúdo legal (markdown)
  privacyPolicy   String?  @map("privacy_policy")  @db.Text
  termsOfUse      String?  @map("terms_of_use")    @db.Text
  exchangePolicy  String?  @map("exchange_policy") @db.Text
  shippingPolicy  String?  @map("shipping_policy") @db.Text
  warrantyPolicy  String?  @map("warranty_policy") @db.Text
  aboutUs         String?  @map("about_us")        @db.Text

  // Comercial
  pixDiscountPercent   Int      @default(5)                    @map("pix_discount_percent")
  shippingFlatRate     Decimal  @default(45.00)                @map("shipping_flat_rate") @db.Decimal(10, 2)
  freeShippingMinValue Decimal? @map("free_shipping_min_value") @db.Decimal(10, 2)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("store_settings")
}

// -----------------------------------------------------------------------------
// WISHLIST — produtos favoritados pelo cliente
// -----------------------------------------------------------------------------
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}

// -----------------------------------------------------------------------------
// CATALOG — Brand × Category × Product × Variation
// -----------------------------------------------------------------------------

model Brand {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  logoUrl   String?  @map("logo_url")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0)    @map("sort_order")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([isActive])
  @@map("brands")
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  isActive  Boolean    @default(true) @map("is_active")
  sortOrder Int        @default(0)    @map("sort_order")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

// =====================================================================
// PRODUCT — modelo central. 4 modos coexistem:
//   - 'componente'  → peça avulsa (CPU/GPU/RAM/...) com `compatibility` JSON
//                     pra builder calcular socket/wattagem/etc
//   - 'pc_pronto'   → PC montado completo, com `specs` (ficha) + `benchmarkFps`
//                     curado + `persona` ligando à landing por uso
//   - 'monitor'     → categoria especial (specs próprias: refresh, painel)
//   - 'periferico'  → mouse/teclado/headset/cadeira (specs leves)
//
// Decisão de schema:
//   - `specs` = ficha técnica humanamente lida na PDP (frontend renderiza)
//   - `compatibility` = chaves usadas pelo BUILDER (socket, tdpW, length_mm...)
//   - `benchmarkFps` = só pra pc_pronto, curado manualmente no MVP
// =====================================================================
model Product {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String   @db.Text
  basePrice    Decimal  @map("base_price")    @db.Decimal(10, 2)
  comparePrice Decimal? @map("compare_price") @db.Decimal(10, 2)  // "preço de"
  brandId      String   @map("brand_id")
  brand        Brand    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  categoryId   String   @map("category_id")
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  isActive     Boolean  @default(true)  @map("is_active")
  isFeatured   Boolean  @default(false) @map("is_featured")
  metaTitle    String?  @map("meta_title")
  metaDesc     String?  @map("meta_desc")
  tags         String[] @default([])

  // ============= ADIÇÕES DE HARDWARE (PESQUISA-NICHO seção 4.3) =============

  // Tipo de produto pro filtro principal
  buildType String? @map("build_type") // 'componente' | 'pc_pronto' | 'monitor' | 'periferico'

  // Categoria técnica (independente de Category model — esta vai pro builder).
  // Ex: 'cpu', 'gpu', 'mobo', 'ram', 'storage', 'psu', 'case', 'cooler',
  //     'pc_full', 'monitor', 'mouse', 'teclado', 'headset', 'cadeira'.
  // Diferente de Category (que é navegação humana — "Placas de vídeo Nvidia").
  hardwareCategory String @default("componente") @map("hardware_category")

  // Slug da persona quando buildType = 'pc_pronto'. Linka /pcs/[slug] →
  // /builds/[persona-slug] (landing SEO).
  personaSlug String? @map("persona_slug")
  persona     Persona? @relation(fields: [personaSlug], references: [slug], onDelete: SetNull)

  // Ficha técnica humanamente legível (renderizada na PDP). Estrutura aberta
  // por categoria — ex CPU: { socket: 'AM5', cores: 8, threads: 16, baseClockGhz: 4.5, boostClockGhz: 5.4, tdpW: 105, ... }
  specs Json? @default("{}")

  // Chaves usadas pelo BUILDER (regra de compatibilidade). Ex:
  //   CPU:    { socket: 'AM5', tdpW: 105, ramType: 'DDR5', maxRamMhz: 5200 }
  //   Mobo:   { socket: 'AM5', chipset: 'B650', ramSlots: 4, ramType: 'DDR5', maxRamMhz: 6000, formFactor: 'ATX', m2Slots: 2 }
  //   RAM:    { type: 'DDR5', mhz: 6000, gb: 16, sticks: 1 }
  //   GPU:    { lengthMm: 320, slots: 3, tdpW: 320, powerConnectors: ['8pin','8pin'], minPsuW: 750 }
  //   PSU:    { wattage: 750, certification: '80+ Gold', modular: 'full', connectors: { gpu_8pin: 2, gpu_12vhpwr: 0 } }
  //   Case:   { formFactor: 'ATX', maxGpuLengthMm: 360, maxCoolerHeightMm: 165, fanSlots: 7 }
  //   Cooler: { sockets: ['AM5','LGA1700'], heightMm: 158, supportsTdpW: 250 }
  //   Storage:{ interface: 'NVMe Gen4', formFactor: 'M.2 2280', gb: 1000 }
  compatibility Json? @default("{}")

  // FPS estimado em jogos populares (curado manual no MVP). Só pra pc_pronto.
  // Ex: { 'valorant_1080p_high': 280, 'cs2_1440p_high': 220, 'fortnite_1440p_epic': 165, 'cyberpunk_4k_dlss_quality': 70 }
  benchmarkFps Json? @map("benchmark_fps")

  // Pra cálculo de frete real (Correios pesa por kg)
  weightGrams   Int?  @map("weight_grams")
  // { lengthMm, widthMm, heightMm }
  dimensionsMm  Json? @map("dimensions_mm")

  // Garantia em meses (CDC = 90 dias mínimo, fabricante normalmente 12-24)
  warrantyMonths Int @default(12) @map("warranty_months")

  // ============= RELAÇÕES =============
  variations    ProductVariation[]
  images        ProductImage[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  waitlist      WaitlistSubscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([brandId])
  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([hardwareCategory])
  @@index([personaSlug])
  @@index([buildType])
  @@map("products")
}

// Variações de produto. Em hardware tem POUCO uso de cor/tamanho — o uso
// principal é "tier" (Bronze/Prata/Ouro pra PCs montados com upgrades de
// RAM/SSD) ou "voltagem" pra PSU. Mas mantemos os campos size/color por
// compatibilidade com o template. Em monitor: size = '27"', color = 'Preto'.
model ProductVariation {
  id            String   @id @default(cuid())
  productId     String   @map("product_id")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku           String   @unique
  size          String                            // ex "Bronze", "27\"", "1TB"
  color         String                            // ex "Preto", "" (vazio se não tem cor)
  colorHex      String?  @map("color_hex")
  stock         Int      @default(0)
  priceOverride Decimal? @map("price_override") @db.Decimal(10, 2)
  isActive      Boolean  @default(true) @map("is_active")

  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@unique([productId, size, color])
  @@index([productId])
  @@index([stock])
  @@map("product_variations")
}

model ProductImage {
  id             String   @id @default(cuid())
  productId      String   @map("product_id")
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variationColor String?  @map("variation_color")
  url            String
  alt            String?
  sortOrder      Int      @default(0)     @map("sort_order")
  isPrimary      Boolean  @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([productId, variationColor])
  @@map("product_images")
}

// =====================================================================
// PERSONA — uso/jogo alvo. Vira landing SEO indexável /builds/[slug].
// Cada PC montado tem uma persona; cliente novato escolhe persona ao invés
// de pesquisar "qual GPU rodar Valorant 240fps".
// =====================================================================
model Persona {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String                                  // "Valorant 240fps"
  headline    String?                                 // hero da landing
  subheadline String?  @db.Text                       // subheader
  description String?  @db.Text                       // texto longo SEO
  // Jogos-alvo: array de strings amigáveis, ex ['Valorant', 'CS2', 'Apex']
  targetGames Json?    @map("target_games")
  // FPS-alvo curado manualmente, ex { 'valorant_1080p_high': 240, 'cs2_1080p_high': 200 }
  targetFps   Json?    @map("target_fps")
  heroImage   String?  @map("hero_image")
  iconEmoji   String?  @map("icon_emoji")             // pra UI rápida ("🎯")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  // SEO
  metaTitle String? @map("meta_title")
  metaDesc  String? @map("meta_desc")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([isActive])
  @@map("personas")
}

// =====================================================================
// PC BUILD — montagem que cliente fez no /montar. Pode ser:
//   - Guest (ownerId nulo): salvo via shareSlug pra ressarguiar do localStorage
//   - Logado: persiste na conta /account/builds
//   - Público (isPublic): aparece em /builds/comunidade futuramente
// =====================================================================
model PCBuild {
  id          String   @id @default(cuid())
  ownerId     String?  @map("owner_id")
  owner       User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  name        String?
  // { cpuId: '...', moboId: '...', ramIds: ['...','...'], gpuId: '...',
  //   psuId: '...', caseId: '...', coolerId: '...', storageIds: ['...'] }
  parts       Json
  totalPrice  Decimal  @map("total_price") @db.Decimal(10, 2)
  totalWattage Int?    @map("total_wattage")
  // Snapshot do último resultado de check-compatibility — pra mostrar status
  // sem re-rodar o check sempre que abrir.
  compatibilityStatus String? @map("compatibility_status")  // 'ok' | 'warning' | 'error'
  isPublic    Boolean  @default(false) @map("is_public")
  shareSlug   String?  @unique @map("share_slug")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([ownerId])
  @@index([isPublic])
  @@map("pc_builds")
}

// =====================================================================
// COMPATIBILITY RULE — tabela de regras pro builder. Não-hardcoded.
// Permite admin mexer sem deploy.
// =====================================================================
model CompatibilityRule {
  id          String   @id @default(cuid())
  ruleType    String   @map("rule_type")     // 'socket_match', 'psu_min_wattage', 'gpu_fits_case', 'cooler_fits_case', 'cooler_supports_tdp', 'ram_compat_mobo', 'mobo_form_factor_case', 'm2_slot_available'
  severity    String                          // 'error' | 'warning'
  message     String                          // mensagem que vai pro cliente, com placeholders {x}
  // Sugestão estruturada. Ex { type: 'upgrade_psu', minWattage: 750 }
  suggestion  Json?
  isActive    Boolean  @default(true) @map("is_active")
  description String?  @db.Text                // pro admin entender pra que serve

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([ruleType])
  @@index([isActive])
  @@map("compatibility_rules")
}

// =====================================================================
// WAITLIST — lista de espera por produto sem estoque (anti-paper-launch).
// Cliente ativa "me avise" → receive notificação quando voltar estoque.
// Idempotente por (productId, email).
// =====================================================================
model WaitlistSubscription {
  id          String    @id @default(cuid())
  productId   String    @map("product_id")
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  email       String
  userId      String?   @map("user_id")
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  notifiedAt  DateTime? @map("notified_at")
  // Nota livre do cliente ("urgente, jogo amanhã!") - opcional
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([productId, email])
  @@index([productId])
  @@index([notifiedAt])
  @@map("waitlist_subscriptions")
}

// -----------------------------------------------------------------------------
// ADDRESS
// -----------------------------------------------------------------------------

model Address {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String?
  recipient  String
  zipcode    String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  country    String   @default("BR")
  phone      String?
  isDefault  Boolean  @default(false) @map("is_default")

  orders Order[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([userId])
  @@map("addresses")
}

// -----------------------------------------------------------------------------
// CART
// -----------------------------------------------------------------------------

model Cart {
  id          String    @id @default(cuid())
  userId      String?   @map("user_id")
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String?   @map("session_id")
  status      String    @default("active")  // "active" | "abandoned" | "converted"
  // Origem do carrinho — usado pra cupons como BUILDER10. Quando o frontend
  // monta carrinho via /montar (PC Builder), envia source='builder' no POST.
  // null = origem orgânica (PDP, busca, navegação). Reset pra null quando
  // o último item é removido (anti-fraude — ver projetos/.../growth/CUPONS.md).
  source      String?
  abandonedAt DateTime? @map("abandoned_at")
  convertedAt DateTime? @map("converted_at")

  items CartItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@map("carts")
}

model CartItem {
  id          String           @id @default(cuid())
  cartId      String           @map("cart_id")
  cart        Cart             @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId   String           @map("product_id")
  product     Product          @relation(fields: [productId], references: [id])
  variationId String           @map("variation_id")
  variation   ProductVariation @relation(fields: [variationId], references: [id])
  quantity    Int              @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@unique([cartId, variationId])
  @@index([cartId])
  @@map("cart_items")
}

// -----------------------------------------------------------------------------
// ORDER
// -----------------------------------------------------------------------------

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique @map("order_number")  // "KT-20260426-0001"
  userId       String      @map("user_id")
  user         User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  status       OrderStatus @default(PENDING_PAYMENT)
  addressId    String      @map("address_id")
  address      Address     @relation(fields: [addressId], references: [id], onDelete: Restrict)

  subtotal     Decimal @db.Decimal(10, 2)
  shippingCost Decimal @map("shipping_cost") @db.Decimal(10, 2)
  discount     Decimal @default(0) @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)

  couponId String? @map("coupon_id")
  coupon   Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)

  notes String? @db.Text

  shippedAt    DateTime? @map("shipped_at")
  deliveredAt  DateTime? @map("delivered_at")
  cancelledAt  DateTime? @map("cancelled_at")
  trackingCode String?   @map("tracking_code")

  items        OrderItem[]
  payments     Payment[]
  couponUsages OrderCouponUsage[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id          String           @id @default(cuid())
  orderId     String           @map("order_id")
  order       Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String           @map("product_id")
  product     Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  variationId String           @map("variation_id")
  variation   ProductVariation @relation(fields: [variationId], references: [id], onDelete: Restrict)

  // SNAPSHOT
  productName    String  @map("product_name")
  variationLabel String  @map("variation_label")
  unitPrice      Decimal @map("unit_price") @db.Decimal(10, 2)
  quantity       Int
  subtotal       Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_items")
}

// -----------------------------------------------------------------------------
// PAYMENT
// -----------------------------------------------------------------------------

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @map("order_id")
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(10, 2)
  installments    Int           @default(1)

  gatewayProvider String  @default("mercadopago") @map("gateway_provider")
  gatewayId       String? @unique                  @map("gateway_id")
  gatewayPayload  Json?   @map("gateway_payload")

  pixQrCode    String?   @map("pix_qr_code")    @db.Text
  pixCopyPaste String?   @map("pix_copy_paste") @db.Text
  pixExpiresAt DateTime? @map("pix_expires_at")

  approvedAt DateTime? @map("approved_at")
  rejectedAt DateTime? @map("rejected_at")
  refundedAt DateTime? @map("refunded_at")

  webhookEventId String? @unique @map("webhook_event_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

// -----------------------------------------------------------------------------
// COUPON
// -----------------------------------------------------------------------------

model Coupon {
  id            String     @id @default(cuid())
  code          String     @unique
  type          CouponType
  value         Decimal?   @db.Decimal(10, 2)
  minOrderValue Decimal?   @map("min_order_value") @db.Decimal(10, 2)
  maxUses       Int?       @map("max_uses")
  usedCount     Int        @default(0) @map("used_count")
  perUserLimit  Int        @default(1) @map("per_user_limit")
  validFrom     DateTime   @default(now()) @map("valid_from")
  validUntil    DateTime?  @map("valid_until")
  isActive      Boolean    @default(true) @map("is_active")

  // ============= REGRAS DE CUPOM (Sprint 2 — projeto-tech/kore-tech/growth/CUPONS.md) =============
  //
  // requiresCartSource — se setado, Cart.source precisa bater (ex: "builder" pra BUILDER10).
  // requiresPaymentMethod — se setado, paymentMethod do checkout precisa bater (ex: "PIX" pra PIXFIRST).
  // requiresCategoryPresence — array de hardwareCategory que TODAS devem estar no carrinho
  //   (ex: COMBO15 = ["pc_full", "periferico"]; o resolver expande "periferico" pro grupo
  //   {mouse,teclado,headset,mousepad,monitor,cadeira} dentro do `lib/coupon.ts`).
  // blockOtherPercent — true = não cumula com outros cupons percent/fixed.
  // stacksWithFreeShipping — true = empilha com FRETE15.
  requiresCartSource       String?   @map("requires_cart_source")
  requiresPaymentMethod    String?   @map("requires_payment_method")
  requiresCategoryPresence String[]  @default([]) @map("requires_category_presence")
  blockOtherPercent        Boolean   @default(true) @map("block_other_percent")
  stacksWithFreeShipping   Boolean   @default(true) @map("stacks_with_free_shipping")

  orders       Order[]
  couponUsages OrderCouponUsage[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

// =====================================================================
// ORDER COUPON USAGE — auditoria de uso de cupom por pedido.
// Sprint 2: usado pra checar limite por usuário (e por email pra guests),
// pra Growth/Data Analyst calcular CAC/ROI por cupom no painel.
// Persiste apenas quando o pedido é commitado (transaction do checkout).
// =====================================================================
model OrderCouponUsage {
  id               String   @id @default(cuid())
  orderId          String   @map("order_id")
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  couponCode       String   @map("coupon_code")
  couponId         String?  @map("coupon_id")
  coupon           Coupon?  @relation(fields: [couponId], references: [id], onDelete: SetNull)
  userId           String?  @map("user_id")
  email            String?
  appliedAt        DateTime @default(now()) @map("applied_at")
  discountValueBRL Decimal  @map("discount_value_brl") @db.Decimal(10, 2)

  @@index([couponCode])
  @@index([userId])
  @@index([orderId])
  @@map("order_coupon_usages")
}

// -----------------------------------------------------------------------------
// REVIEW
// -----------------------------------------------------------------------------

model Review {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int                                  // 1..5
  comment    String?  @db.Text
  isApproved Boolean  @default(false) @map("is_approved")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  @@unique([productId, userId])
  @@index([productId])
  @@index([isApproved])
  @@map("reviews")
}
