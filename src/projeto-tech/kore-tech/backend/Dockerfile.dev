# =============================================================================
# Backend Kore Tech — Dockerfile DEV
#
# Usa Node 20 slim (Debian-based) em vez de alpine: o Prisma engine precisa
# de OpenSSL/glibc, e a detecção em alpine 3.23+ é fragil. Slim pesa um
# pouco mais (~150MB vs 50MB) mas evita o problema conhecido do Prisma.
#
# Hot reload via volume mount no docker-compose (tsx watch).
# =============================================================================

FROM node:20-slim

# Pacotes do sistema:
#   - openssl + ca-certificates: requeridos pelo Prisma engine
#   - postgresql-client: pra wait-for-postgres + debug interativo
#   - tini: PID 1 que repassa SIGTERM corretamente (graceful shutdown)
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      openssl \
      ca-certificates \
      postgresql-client \
      tini \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copia manifestos primeiro (cache de layer)
COPY package.json package-lock.json* ./

# Instala dependências (incluindo dev pra rodar tsx watch)
RUN npm install

# Copia o resto (em dev, volume mount sobrescreve, mas precisa pra primeiro build)
COPY . .

# Gera o Prisma client a partir do schema
RUN npx prisma generate

# Tini como init (pega SIGTERM corretamente)
ENTRYPOINT ["/usr/bin/tini", "--"]

EXPOSE 4001

# Em dev: aplica migrations pendentes (no-op se não houver) e sobe com hot reload
CMD ["sh", "-c", "npx prisma migrate deploy && npm run dev"]
