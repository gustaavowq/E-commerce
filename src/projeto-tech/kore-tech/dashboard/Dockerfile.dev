# =============================================================================
# Dashboard Kore Tech — Dockerfile DEV
# Mantido pelo DevOps (Agente 05).
#
# Next.js 14 painel admin em modo dev com hot reload. Roda na porta 3002.
# IMPORTANTE: o agente Frontend ainda precisa criar o package.json do dashboard
# com script "dev": "next dev -p 3002" — esse Dockerfile espera isso.
# =============================================================================

FROM node:20-slim

RUN apt-get update \
 && apt-get install -y --no-install-recommends tini ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Manifests primeiro (cache layer)
COPY package.json package-lock.json* ./
RUN npm install

# O resto do codigo (sobrescrito pelo volume mount em dev)
COPY . .

ENTRYPOINT ["/usr/bin/tini", "--"]

EXPOSE 3002

# Polling pra hot reload funcionar em volume mount no Windows/macOS
ENV WEBPACK_POLLING=true
ENV WATCHPACK_POLLING=true

CMD ["npm", "run", "dev"]
