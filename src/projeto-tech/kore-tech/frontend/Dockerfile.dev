# =============================================================================
# Frontend Kore Tech — Dockerfile DEV
# Mantido pelo DevOps (Agente 05).
#
# Next.js 14 em modo dev com hot reload. Roda na porta 3001 (script "next dev -p 3001").
# Usa node:20-slim por consistencia com o backend.
# =============================================================================

FROM node:20-slim

RUN apt-get update \
 && apt-get install -y --no-install-recommends tini ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Manifests primeiro (cache layer)
COPY package.json package-lock.json* ./
RUN npm install

# O resto do codigo (sobrescrito pelo volume mount em dev)
COPY . .

ENTRYPOINT ["/usr/bin/tini", "--"]

EXPOSE 3001

# Polling pra hot reload funcionar em volume mount no Windows/macOS
ENV WEBPACK_POLLING=true
ENV WATCHPACK_POLLING=true

CMD ["npm", "run", "dev"]
